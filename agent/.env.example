PORT=8001

# ServiceNow developer instance
SERVICENOW_INSTANCE=dev282934
SERVICENOW_USER=admin
SERVICENOW_PASSWORD=replace-me

# Optional: enables LLM-generated descriptions in the 'triage' node.
# Works with any OpenAI-compatible endpoint, including a local LiteLLM proxy.
#
# OpenAI directly:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
#
# LiteLLM proxy (e.g. routing to Anthropic claude-sonnet):
# OPENAI_BASE_URL=http://localhost:4000/v1
# OPENAI_API_KEY=sk-litellm-local
# OPENAI_MODEL=claude-sonnet

# ── Remediation settings ───────────────────────────────────────────────────
# Absolute path to a local git checkout of the application repository.
# The rcaAnalysis and applyFix nodes read/write files relative to this path,
# and openPR runs git/gh commands here.
# In Docker / AWS: set to /repo (the COPY destination in the Dockerfile).
REPO_ROOT=/repo

# Base branch for the auto-generated pull request.
GIT_DEFAULT_BRANCH=master

# ── Sandbox (Docker-based) ─────────────────────────────────────────────────
# deploySandbox builds a Docker image from the patched app/server source and
# starts an ephemeral container on a dedicated bridge network. The agent and
# sandbox communicate over Docker DNS — no port publishing is needed.
#
# The agent container must have access to a Docker daemon:
#   docker run -v /var/run/docker.sock:/var/run/docker.sock ...
#
# ECS EC2 (bridge/host networkMode): supported — mount the host socket.
# ECS Fargate: no Docker socket available; sandbox is skipped and
#              verifyScenario falls back to inline code analysis.
#
# SANDBOX_PORT  Internal port the app server listens on inside its container.
#               Must match SERVER_PORT in app/server/Dockerfile (default 3001).
SANDBOX_PORT=3001
