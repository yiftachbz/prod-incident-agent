# Port the Fastify server listens on.
# In Docker / AWS set via SERVER_PORT environment variable.
SERVER_PORT=3001

# ── Internal log endpoint authentication ──────────────────────────────────
# Shared secret for GET /api/_logs and GET /api/_logs/recent-errors.
# The agent sends this as X-Logs-Token. Must match LOGS_TOKEN in agent/.env.
# When unset the endpoints return 503 (fail-closed).
LOGS_TOKEN=replace-with-a-strong-random-secret

# Override the JSONL log file location (default: <cwd>/logs/server.jsonl).
# LOG_PATH=/var/log/netprovision/server.jsonl
